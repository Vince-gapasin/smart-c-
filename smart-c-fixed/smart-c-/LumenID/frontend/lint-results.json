arNavigation } from \"./navigation/SidebarNavigation\";\r\nimport { useAuth } from \"../contexts/AuthContext\";\r\n\r\nexport function Layout() {\r\n  const location = useLocation();\r\n  const { isAuthenticated, user } = useAuth();\r\n\r\n  const isCustomerRoute = location.pathname.startsWith(\"/customer\");\r\n  const isAdminRoute = location.pathname.startsWith(\"/admin\");\r\n\r\n  // Keep navigation hidden on profile creation step or auth paths\r\n  const shouldRenderSidebar = isAuthenticated && (isCustomerRoute || isAdminRoute) && location.pathname !== \"/customer/profile-creation\";\r\n\r\n  if (shouldRenderSidebar) {\r\n    return (\r\n      <div className=\"min-h-screen bg-background flex flex-col lg:flex-row w-full overflow-hidden\">\r\n        <SidebarNavigation />\r\n        <main className=\"flex-1 lg:h-screen lg:overflow-y-auto page-shell pt-20 lg:pt-8 custom-scrollbar\">\r\n          <div className=\"page-container w-full max-w-7xl mx-auto\">\r\n            <Outlet />\r\n          </div>\r\n        </main>\r\n      </div>\r\n    );\r\n  }\r\n\r\n  // Public/Auth routes get no navigation at all, just content\r\n  return (\r\n    <div className=\"min-h-screen bg-background\">\r\n      <main id=\"main-content\" className=\"page-shell\">\r\n        <div className=\"page-container\">\r\n          <Outlet />\r\n        </div>\r\n      </main>\r\n    </div>\r\n  );\r\n}","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Admin\\Documents\\GitHub\\LumenID\\frontend\\src\\components\\NotFoundPage.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Admin\\Documents\\GitHub\\LumenID\\frontend\\src\\components\\PageTransition.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Admin\\Document